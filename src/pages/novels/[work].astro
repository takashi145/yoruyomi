---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const allChapters = await getCollection("novels");
  const slugs = [...new Set(allChapters.map((e) => e.data.workSlug))];

  return slugs.map((work) => {
    const chapters = allChapters
      .filter((e) => e.data.workSlug === work)
      .sort((a, b) => a.data.chapterNumber - b.data.chapterNumber);
    return { params: { work }, props: { chapters } };
  });
}

const { chapters } = Astro.props;
const first = chapters[0];
const { workTitle, workSlug, synopsis, genre, status, publishedAt } = first.data;
const firstChSlug = first.id.replace(`${workSlug}/`, "").replace(/\.md$/, "");
---

<Base title={workTitle} description={synopsis}>
  <div class="work-page">

    <nav class="breadcrumb">
      <a href="/">夜読み</a>
      <span>›</span>
      <a href="/novels">作品一覧</a>
      <span>›</span>
      <span>{workTitle}</span>
    </nav>

    <div class="work-header">
      <div class="work-badges">
        {genre?.map((g) => <span class="badge badge-genre">{g}</span>)}
        <span class={`badge badge-${status}`}>{status === "complete" ? "完結" : "連載中"}</span>
      </div>
      <h1 class="work-title">{workTitle}</h1>
      <p class="work-date">{publishedAt.toLocaleDateString("ja-JP")}</p>
      {synopsis && <p class="work-synopsis">{synopsis}</p>}
    </div>

    <hr />

    <p class="toc-label">目次</p>
    <ol class="toc-list">
      {chapters.map((ch) => {
        const chSlug = ch.id.replace(`${workSlug}/`, "").replace(/\.md$/, "");
        return (
          <li>
            <a href={`/novels/${workSlug}/${chSlug}`} class="toc-row">
              <span class="toc-num">{String(ch.data.chapterNumber).padStart(2, "0")}</span>
              <span class="toc-title">{ch.data.title}</span>
            </a>
          </li>
        );
      })}
    </ol>

    <div class="work-cta">
      <a href={`/novels/${workSlug}/${firstChSlug}`} class="btn btn-primary">
        第1章から読む →
      </a>
    </div>

  </div>
</Base>

<style>
  .work-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
  }

  .breadcrumb {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.75rem;
    color: var(--text-dim);
    font-family: sans-serif;
    margin-bottom: 2.5rem;
  }
  .breadcrumb a { color: var(--text-dim); transition: color 0.15s; }
  .breadcrumb a:hover { color: var(--text-sub); }

  .work-header { margin-bottom: 2.5rem; }
  .work-badges { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .work-title { font-size: 1.8rem; line-height: 1.3; margin-bottom: 0.6rem; }
  .work-date { font-size: 0.78rem; color: var(--text-dim); font-family: sans-serif; margin-bottom: 1rem; }
  .work-synopsis { color: var(--text-sub); line-height: 1.85; max-width: 52ch; font-size: 0.95rem; }

  .toc-label {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-family: sans-serif;
    margin: 2rem 0 0.8rem;
  }
  .toc-list { list-style: none; }
  .toc-list li { border-top: 1px solid var(--border); }
  .toc-list li:last-child { border-bottom: 1px solid var(--border); }

  .toc-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.85rem 0.6rem;
    margin: 0 -0.6rem;
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
  }
  .toc-row:hover { background: var(--surface); }
  .toc-row:hover .toc-title { color: var(--accent); }

  .toc-num {
    font-size: 0.68rem;
    color: var(--text-dim);
    font-family: sans-serif;
    min-width: 1.8rem;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .toc-row:hover .toc-num { color: var(--accent); }
  .toc-title { font-size: 0.95rem; transition: color 0.15s; }

  .work-cta { margin-top: 2.5rem; }
</style>
