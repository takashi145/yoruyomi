---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "夜読み — 小説サイト" } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | 夜読み</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-logo">夜<em>読み</em></a>
    </header>

    <slot />
  </body>
</html>
